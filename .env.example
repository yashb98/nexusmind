# NexusMind Environment Variables
# Copy to .env and fill in your values

# ── PostgreSQL (Supabase) ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexusmind

# ── Neo4j ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexusmind_dev

# ── Qdrant ──
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── LLM (Primary: Local MLX on Mac Studio) ──
MLX_MODEL_PATH=mlx-community/Qwen2.5-7B-Instruct-4bit
MLX_ADAPTER_DIR=./adapters

# ── LLM (Fallback: Anthropic via LiteLLM) ──
ANTHROPIC_API_KEY=your_anthropic_key
LITELLM_FALLBACK_MODEL=anthropic/claude-sonnet-4-20250514

# ── Embedding ──
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Web Search ──
SEARXNG_URL=http://localhost:8080

# ── Avatar (RunPod burst for SadTalker) ──
RUNPOD_API_KEY=your_runpod_key
SADTALKER_ENDPOINT=

# ── TTS ──
EDGE_TTS_VOICE=en-GB-SoniaNeural

# ── Observability ──
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Auth ──
JWT_SECRET=change-this-to-random-256-bit-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── App ──
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# ── Fine-Tuning (Environment Layer) ──
FINETUNE_CRON=0 2 * * *
FINETUNE_MIN_QUALITY=4.0
FINETUNE_ITERS=500
FINETUNE_BATCH_SIZE=4
FINETUNE_LORA_LAYERS=16
FINETUNE_PERSONALITY_VARIANCE_THRESHOLD=0.5
FINETUNE_MIN_EXAMPLES=50
